<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ffffff">

    <LinearLayout
        android:id="@+id/root"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#ffffff">

    <!-- 主体：聊天 + WebView + 输入（无顶栏、无侧栏） -->
    <FrameLayout
            android:id="@+id/mainContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="#fdfdfd">

            <!-- 上半部分：聊天 + WebView + 输入（与 logPanel 分权重） -->
            <LinearLayout
                android:id="@+id/editorContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical">

            <!-- 聊天列表（含网页预览气泡，仅当 Python 调用 loadHtml 时出现） -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/chatList"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:scrollbars="none"
                tools:listitem="@layout/item_chat_her_ai" />

            <!-- 底部输入 + 日志按钮（悬浮样式，底部留出空间，支持多行输入的最小/最大高度） -->
            <LinearLayout
                android:id="@+id/inputContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="16dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:background="@drawable/bg_input_bar_ripple"
                android:clickable="true"
                android:focusable="true"
                android:elevation="2dp">

                <!-- 选中文件条：图标、名称、类型大小、取消 -->
                <LinearLayout
                    android:id="@+id/fileStrip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="10dp"
                    android:paddingEnd="8dp"
                    android:background="@drawable/bg_file_strip"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_note"
                        android:padding="6dp"
                        android:tint="#4F46E5" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:id="@+id/fileStripName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="#111827"
                            android:maxLines="1"
                            android:ellipsize="middle" />

                        <TextView
                            android:id="@+id/fileStripMeta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textSize="12sp"
                            android:textColor="#6B7280" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/fileStripCancel"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:elevation="2dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_close"
                        android:scaleType="centerInside"
                        android:contentDescription="取消选择"
                        android:tint="#6B7280"
                        android:padding="6dp" />
                </LinearLayout>

                <EditText
                    android:id="@+id/inputEdit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="44dp"
                    android:maxHeight="140dp"
                    android:background="@android:color/transparent"
                    android:hint="输入指令…"
                    android:textSize="14sp"
                    android:textColor="#383838"
                    android:textColorHint="#787878"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:maxLines="6"
                    android:scrollbars="vertical"
                    android:overScrollMode="ifContentScrolls"
                    android:inputType="textMultiLine|textCapSentences"
                    android:imeOptions="actionSend" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <ImageButton
                        android:id="@+id/btnAddFile"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:elevation="2dp"
                        android:background="@drawable/bg_btn_input_circle"
                        android:src="@drawable/baseline_add_24"
                        android:scaleType="centerInside"
                        android:contentDescription="添加文件"
                        android:tint="#111827" />

                    <ImageButton
                        android:id="@+id/btnLog"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="6dp"
                        android:elevation="2dp"
                        android:background="@drawable/bg_btn_input_circle"
                        android:src="@drawable/ic_log"
                        android:scaleType="centerInside"
                        android:contentDescription="终端日志"
                        android:tint="#111827" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <ImageButton
                        android:id="@+id/sendButton"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="6dp"
                        android:elevation="2dp"
                        android:background="@drawable/bg_btn_input_circle"
                        android:src="@drawable/ic_send_rounded"
                        android:scaleType="centerInside"
                        android:contentDescription="发送"
                        android:tint="#111827" />
                </LinearLayout>
            </LinearLayout>
            </LinearLayout>

            <!-- 执行日志面板（可拖拽调节高度） -->
            <LinearLayout
                android:id="@+id/logPanel"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0"
                android:orientation="vertical"
                android:alpha="0"
                android:background="#F9FAFB"
                android:visibility="visible">

                <!-- 头部：标题 + 清空 + 关闭 -->
                <LinearLayout
                    android:id="@+id/logBar"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="10dp"
                    android:background="#F1F5F9">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="执行日志"
                        android:textSize="12.5sp"
                        android:textColor="#4B5563"
                        android:letterSpacing="0.03" />

                    <!-- 清空日志 -->
                    <ImageView
                        android:id="@+id/btnClearLog"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_delete"
                        android:tint="#9CA3AF"
                        android:padding="5dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="清空日志" />

                    <!-- 关闭面板 -->
                    <ImageView
                        android:id="@+id/btnCloseLog"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_close"
                        android:tint="#9CA3AF"
                        android:padding="5dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="关闭日志" />
                </LinearLayout>

                <!-- 日志列表 -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/execLogList"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="#F9FAFB"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:clipToPadding="false"
                    android:scrollbars="none" />

                <!-- 空状态 -->
                <TextView
                    android:id="@+id/tvExecLogEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="暂无执行记录"
                    android:textSize="13sp"
                    android:textColor="#D1D5DB"
                    android:visibility="gone" />

            </LinearLayout>
            </LinearLayout>

            <!-- 覆盖层：用于 DepsInstall 等 Fragment -->
        <FrameLayout
                android:id="@+id/frameOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                android:background="#80000000" />

            <!-- 左上角：描边圆形按钮，点击打开历史会话抽屉 -->
            <ImageButton
                android:id="@+id/btnDrawerMenu"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="start|top"
                android:layout_marginStart="12dp"
                android:layout_marginTop="12dp"
                android:elevation="2dp"
                android:background="@drawable/bg_btn_drawer_menu"
                android:src="@drawable/ic_menu"
                android:scaleType="centerInside"
                android:contentDescription="历史会话"
                android:tint="#374151"
                android:padding="10dp" />
        </FrameLayout>
    </LinearLayout>

    <!-- 左侧抽屉：历史会话列表 -->
    <include
        android:id="@+id/drawerSessions"
        layout="@layout/drawer_sessions"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start" />
</androidx.drawerlayout.widget.DrawerLayout>
